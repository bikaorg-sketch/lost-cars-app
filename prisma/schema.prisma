generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(cuid())
  name          String
  email         String    @unique
  phone         String?
  password      String
  role          String    @default("user")
  createdAt     DateTime  @default(now())
  reports       Report[]
  sightings     Sighting[]
  conversations Conversation[] @relation("ConvInitiator")
  messages      Message[]
  notifications Notification[]
}

model Conversation {
  id          String   @id @default(cuid())
  type        String   // "support" | "report"
  reportId    String?
  report      Report?  @relation(fields: [reportId], references: [id], onDelete: Cascade)
  initiatorId String
  initiator   User     @relation("ConvInitiator", fields: [initiatorId], references: [id], onDelete: Cascade)
  messages    Message[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([initiatorId])
  @@index([reportId])
  @@index([updatedAt])
}

model Message {
  id             String   @id @default(cuid())
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  senderId       String
  sender         User     @relation(fields: [senderId], references: [id], onDelete: Cascade)
  body           String
  createdAt      DateTime @default(now())
  readAt         DateTime?
  deletedAt      DateTime?

  @@index([conversationId, createdAt])
}

model Report {
  id            String    @id @default(cuid())
  plateNumber   String?
  chassisNumber String?
  brand         String
  model         String
  year          Int?
  color         String
  description   String?
  lostAt        DateTime?
  lostCity      String
  lostArea      String?
  latitude      Float?
  longitude     Float?
  contactName   String
  contactPhone  String
  contactEmail  String?
  reward        Float?
  status        String    @default("pending")
  deletionRequestedAt DateTime?
  deletionReason      String?
  ownerId       String
  owner         User      @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  images        ReportImage[]
  sightings     Sighting[]
  conversations Conversation[]
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([plateNumber])
  @@index([chassisNumber])
  @@index([status])
}

model ReportImage {
  id        String   @id @default(cuid())
  url       String
  reportId  String
  report    Report   @relation(fields: [reportId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
}

model Sighting {
  id          String   @id @default(cuid())
  reportId    String
  report      Report   @relation(fields: [reportId], references: [id], onDelete: Cascade)
  reporterId  String?
  reporter    User?    @relation(fields: [reporterId], references: [id], onDelete: SetNull)
  description String
  city        String
  area        String?
  latitude    Float?
  longitude   Float?
  contactPhone String?
  seenAt      DateTime?
  status      String   @default("pending")
  createdAt   DateTime @default(now())

  @@index([reportId, createdAt])
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      String   // 'message' | 'sighting' | 'report_status' | 'system'
  title     String
  body      String?
  link      String?
  readAt    DateTime?
  createdAt DateTime @default(now())

  @@index([userId, createdAt])
  @@index([userId, readAt])
}
