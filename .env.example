# Database (SQLite by default - works out of the box).
# For production, switch to PostgreSQL: "postgresql://user:pass@host:5432/dbname"
DATABASE_URL="file:./dev.db"

# NextAuth - REQUIRED.
# Generate a strong secret: `openssl rand -base64 32`
# Never share this in source control. The example value below is NOT secure.
NEXTAUTH_SECRET="replace-me-with-a-random-32-char-string"

# Public URL of the app (no trailing slash)
NEXTAUTH_URL="http://localhost:3000"
