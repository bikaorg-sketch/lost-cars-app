# Database — PostgreSQL connection string.
# Get a free one from Neon: https://console.neon.tech/
# Example: postgresql://user:password@ep-xxx.us-east-1.aws.neon.tech/neondb?sslmode=require
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DBNAME?sslmode=require"

# NextAuth secret — REQUIRED.
# Generate a strong secret with one of:
#   openssl rand -base64 32
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
NEXTAUTH_SECRET="replace-me-with-a-random-32-char-string"

# Public URL of the app (no trailing slash).
# - Local dev:   http://localhost:3000
# - Production:  https://your-app.vercel.app
NEXTAUTH_URL="http://localhost:3000"
